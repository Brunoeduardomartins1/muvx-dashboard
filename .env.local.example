# Credenciais admin MUVX (obrigatório)
MUVX_EMAIL=admin@seudominio.com
MUVX_PASSWORD=suasenha

# Base URL da API (padrão: https://api.muvx.app)
MUVX_API_BASE=https://api.muvx.app

# Opcional: token pré-obtido (prioridade sobre email/senha)
# MUVX_API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Meta de receita mensal (em BRL, padrão: 50000)
NEXT_PUBLIC_MUVX_GOAL=50000
